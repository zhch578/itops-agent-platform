# 简化版 - 直接使用官方 Node.js
FROM node:20

# 设置工作目录
WORKDIR /app

# 设置 npm 使用国内镜像源
RUN npm config set registry https://registry.npmmirror.com

# 先复制 package 文件
COPY backend/package*.json ./

# 安装依赖
RUN npm install

# 复制后端源代码
COPY backend/ ./

# 构建 TypeScript 代码
RUN npm run build

# 环境变量
ENV NODE_ENV=production
ENV PORT=3001
ENV HOST=0.0.0.0

# 安装 Python 和 pip（dbskiter 依赖），构建时失败不阻塞镜像构建
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*
RUN python3 -m pip install --upgrade pip || true
RUN python3 -m pip install dbskiter || true

# 创建数据目录
RUN mkdir -p /app/data

# 暴露端口
EXPOSE 3001

# 启动应用
CMD ["node", "dist/app.js"]
