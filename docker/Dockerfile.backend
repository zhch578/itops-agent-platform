# ITOps Agent Platform - Backend
# Multi-stage build optimized for production and public registry distribution
# Build: docker build -f docker/Dockerfile.backend -t itops-backend:latest .

# ============================================================
# Stage 1: Builder
# ============================================================
FROM node:20-slim AS builder

# Use Aliyun Debian mirror for faster and more reliable apt access in China
# Note: Must use HTTP (not HTTPS) because node:20-slim lacks ca-certificates
RUN sed -i 's|http://deb.debian.org/debian|http://mirrors.aliyun.com/debian|g; s|http://security.debian.org/debian-security|http://mirrors.aliyun.com/debian-security|g' /etc/apt/sources.list.d/debian.sources

WORKDIR /app

# Install build dependencies for native modules (better-sqlite3)
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    make \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# Copy package files first for better layer caching
COPY backend/package.json backend/package-lock.json ./

# Install all dependencies and build native modules
RUN npm ci

# Copy source code
COPY backend/ ./

# Build TypeScript to JavaScript
RUN npm run build

# ============================================================
# Stage 2: Production
# ============================================================
FROM node:20-slim

# Use Aliyun Debian mirror for faster and more reliable apt access in China
# Note: Must use HTTP (not HTTPS) because node:20-slim lacks ca-certificates
RUN sed -i 's|http://deb.debian.org/debian|http://mirrors.aliyun.com/debian|g; s|http://security.debian.org/debian-security|http://mirrors.aliyun.com/debian-security|g' /etc/apt/sources.list.d/debian.sources

# Labels for public registry (replace with your actual info)
LABEL maintainer="谭策 <huawei_network@foxmail.com>" \
      org.opencontainers.image.title="ITOps Agent Platform Backend" \
      org.opencontainers.image.description="Enterprise IT Operations Multi-Agent Automation Platform - Backend API Server" \
      org.opencontainers.image.source="https://github.com/qinshihu/itops-agent-platform" \
      org.opencontainers.image.licenses="MPL-2.0" \
      org.opencontainers.image.vendor="谭策" \
      org.opencontainers.image.url="https://www.zjzwfw.cloud/ITOpsAgentinfo"

# Set working directory
WORKDIR /app

# Environment variables
ENV NODE_ENV=production \
    PORT=3001 \
    HOST=0.0.0.0

# Install runtime dependencies (SQLite library, Python for dbskiter, gosu for privilege dropping)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libsqlite3-0 \
    python3 \
    python3-pip \
    gosu \
    && rm -rf /var/lib/apt/lists/*

# 安装 dbskiter（数据库运维 Agent 依赖），构建时失败不阻塞镜像构建
# Debian 12 (bookworm) 使用 PEP 668 限制系统级 pip 安装，需要 --break-system-packages
RUN python3 -m pip install --upgrade pip --break-system-packages || true
RUN python3 -m pip install dbskiter --break-system-packages || true

# Copy built application from builder stage
COPY --from=builder /app/dist ./dist

# Copy node_modules from builder (already compiled with native modules)
COPY --from=builder /app/node_modules ./node_modules

# Copy package.json for reference
COPY backend/package.json ./

# Copy entrypoint script
COPY docker/docker-entrypoint-backend.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# Create data directory for SQLite database
RUN mkdir -p /app/data

# Create non-root user
RUN addgroup --system --gid 1001 appgroup && \
    adduser --system --uid 1001 --ingroup appgroup appuser

# Set proper ownership
RUN chown -R appuser:appgroup /app

# Expose API port
EXPOSE 3001

# Health check endpoint
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD node -e "require('http').get('http://localhost:3001/health', (r) => {process.exit(r.statusCode === 200 ? 0 : 1)})"

# Use entrypoint script for proper volume permission handling
ENTRYPOINT ["docker-entrypoint.sh"]

# Start the application
CMD ["node", "dist/app.js"]